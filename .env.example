# Supabase Configuration
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Google Analytics Configuration
# Get your GA ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX (for GA4) or UA-XXXXXXXXX (for Universal Analytics)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Google Search Console Configuration
# Get your verification token from: https://search.google.com/search-console
# In Google Search Console, go to Settings > Verification > Google Analytics or HTML tag
# Copy the content attribute value from the meta tag
NEXT_PUBLIC_GOOGLE_SEARCH_CONSOLE_TOKEN=
